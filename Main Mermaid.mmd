flowchart TD

%% Nodes
A([Start]) --> B[Document Input]

B --> C{TOC Exists?}
C -- No --> D[User Adds TOC]
D --> B
C -- Yes --> E["Extract Text (OCR + Native) & Assets"]

E --> F[TOC-based Sectioning]
F --> G[Dual-layer Chunking]
G --> H[Attach Metadata & Assets]
H --> I[Generate Summaries & References]

I --> J[(Store: Chunks + Summaries + Metadata)]

J --> K[User Query]

K --> L[Query Planning Agent]

L --> M[Parallel Retrieval Agents]
M --> N[Context Filtering Agent]
N --> O[Query Augmentation Agent]

O --> P[LLM Reasoning]

P --> Q{Need More Context?}
Q -- Yes --> M
Q -- No --> R{Context Sufficient?}

R -- No --> S["Fallback Generation (Explain)"]
R -- Yes --> T[Grounded Answer]

S --> U[Response + Assets + Traceability]
T --> U

U --> V([End])

%% Color Styling
classDef process fill:#E8F5E9,stroke:#2E7D32,stroke-width:1px;
classDef decision fill:#FFEBEE,stroke:#C62828,stroke-width:1px;
classDef llm fill:#FFF3E0,stroke:#EF6C00,stroke-width:1px;
classDef data fill:#E3F2FD,stroke:#1565C0,stroke-width:1px;

class B,E,F,G,H,I,K,L,M,N,O,S,T,U process;
class C,Q,R decision;
class P llm;
class J data;
